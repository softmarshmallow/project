# =============================================================================
# stage-gen environment configuration
#
# All AI-SDK calls (image-gen + text-gen) route through the Vercel AI Gateway.
# Copy this file to `.env` at repo root and fill in real values.
# Each workspace that needs env access gets its own COPY (web/.env.local etc.)
# — do not symlink. The pipeline CLI loads `.env` from the repo root.
# =============================================================================

# Vercel AI Gateway API key — auth for ALL AI SDK calls (image + text).
# The SDK auto-detects this env var; no explicit base URL needed at call sites.
# Required by: pipeline (every generator), web (if it ever calls the SDK directly).
AI_GATEWAY_API_KEY=vck_...

# Vercel AI Gateway base URL. Optional — the SDK defaults to the public gateway.
# Override only when targeting a self-hosted or staging gateway.
# AI_GATEWAY_BASE_URL=https://ai-gateway.vercel.sh/v1

# Image-generation model id (Wave 1, Wave 2, Wave 3 image calls).
# Defaults to `openai/gpt-image-2` — the model the asset contracts target.
# IMAGE_MODEL=openai/gpt-image-2

# Text-generation / vision model id for the world-design agent (Wave 1.5).
# Defaults to `openai/gpt-5.5` — flagship vision LLM, no fallback chain.
# TEXT_MODEL=openai/gpt-5.5

# Output root for generated worlds (per-tag subdirs land here).
# Defaults to `<repo-root>/out`. Gitignored.
# OUT_DIR=out
